{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,
    "modules-left": ["custom-start", "sway/workspaces", "sway/mode"],
    "modules-center": [],
    "modules-right": [
        "custom/power",
        "battery",
        "custom-gammastep", 
        "idle_inhibitor", 
        "cpu", 
        "memory", 
        "network#speed",
        "tray", 
        "pulseaudio", 
        "network", 
        "clock"
    ],

    "custom-start": {
        "format": " Inicio",
        "on-click": "rofi -show drun",
        "tooltip": false
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },

    "custom/power": {
        "exec": "tuned-adm active | awk '{print $NF}'",
        "interval": 5,
        "format": "Modo: {}",
        "on-click": "tuned-adm profile throughput-performance",
        "on-click-right": "tuned-adm profile balanced",
        "tooltip": false
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "Bat: {capacity}%",
        "format-charging": "Carga: {capacity}%",
        "format-plugged": "AC: {capacity}%",
        "tooltip-format": "{timeTo}"
    },

    "custom-gammastep": {
        "interval": 2,
        "exec": "pgrep -x gammastep > /dev/null && echo 'Luz: ON' || echo 'Luz: OFF'",
        "format": "{}",
        "on-click": "pgrep -x gammastep > /dev/null && killall gammastep || gammastep -m wayland -l 53.3:-6.2 -O 3500 &",
        "tooltip": false
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "Activo",
            "deactivated": "Idle"
        }
    },

    "cpu": {
        "interval": 5,
        "format": "CPU: {usage}%",
        "tooltip": false
    },

    "memory": {
        "interval": 10,
        "format": "RAM: {percentage}%",
        "tooltip": false
    },

    "network#speed": {
        "interval": 2,
        "format": "D:{bandwidthDownBits} U:{bandwidthUpBits}",
        "format-disconnected": "OFFLINE",
        "tooltip": false
    },

    "tray": {
        "spacing": 10
    },

    "clock": {
        "timezone": "Europe/Dublin",
        "format": "{:%I:%M %p}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#000080'><b>{}</b></span>",
                "days": "<span color='#000000'>{}</span>",
                "weeks": "<span color='#808080'>w{}</span>",
                "weekdays": "<span color='#800000'><b>{}</b></span>",
                "today": "<span color='#ffffff' background='#000080'><b>{}</b></span>"
            }
        }
    },

    "pulseaudio": {
        "format": "Vol: {volume}%",
        "format-muted": "Mudo",
        "on-click": "pavucontrol"
    },

    "network": {
        "format-wifi": "WiFi",
        "format-ethernet": "Eth",
        "format-disconnected": "Desconectado"
    }
}

